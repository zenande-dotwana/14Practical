// Open hashing (linear probing) implementation- Table indices from 1 to m
 
public class OpenHash {
    private KeyValuePair[] table;
    private int m; // table size
    private int size; // number of elements inserted
    private int collisions; // collision counter for analysis
    
    public OpenHash(int m) {
        this.m = m;
        this.table = new KeyValuePair[m + 1]; // index from 1 to m
        this.size = 0;
        this.collisions = 0;
    }
    
    // Hash function - returns index in [1, m] Using polynomial hash code for strings
     
    private int hash(String key) {
        final int base = 31; // common prime base for string hashing
        long hash = 0;
        
        for (int i = 0; i < key.length(); i++) {
            hash = (hash * base + key.charAt(i)) % m;
        }
        
        // Ensure result is in [1, m]
        return (int)((hash % m) + 1);
    }
    
    // Insert key-value pair using open addressing with linear probing
     
    public void insert(String key, String value) {
        int index = hash(key);
        int originalIndex = index;
        boolean foundEmpty = false;
        
        // Linear probing
        while (table[index] != null) {
            // If key already exists, update value
            if (table[index].getKey().equals(key)) {
                table[index].setValue(value);
                return;
            }
            
            collisions++;
            index = (index % m) + 1; // wrap around to 1..m
            
            // If we've checked all positions, table is full
            if (index == originalIndex) {
                throw new RuntimeException("Hash table is full");
            }
        }
// Found empty slot
        table[index] = new KeyValuePair(key, value);
        size++;
    }
    
    // Look up value by key
     
    public String lookup(String key) {
        int index = hash(key);
        int originalIndex = index;
        
        // Linear probing until we find the key or hit an empty slot
        while (table[index] != null) {
            if (table[index].getKey().equals(key)) {
                return table[index].getValue();
            }
            
            index = (index % m) + 1;
            
            // If we've checked all positions, key not found
            if (index == originalIndex) {
                break;
            }
        }
        
        return null; // key not found
    }
    
    // Check if key is in table
     
    public boolean isInTable(String key) {
        return lookup(key) != null;
    }
    
    public int getSize() {
        return size;
    }
    
    public int getCollisions() {
        return collisions;
    }
    
    public double getLoadFactor() {
        return (double) size / m;
    }
}

